// Prisma schema for Mentivo
// Docs: https://pris.ly/d/prisma-schema
// Connection URLs are configured in prisma.config.ts (Prisma v7+)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth required models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // Nullable — Google users won't have a password
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  projects Project[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── Mentivo App Models ────────────────────────────────────────────────────────

model Project {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  idea      String        @db.Text
  status    ProjectStatus @default(ONBOARDING)
  level     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages  Message[]
  quiz      Quiz?
  roadmap   Roadmap?
}

model Roadmap {
  id        String      @id @default(cuid())
  projectId String      @unique
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  milestones Milestone[]
}

model Milestone {
  id             String          @id @default(cuid())
  roadmapId      String
  roadmap        Roadmap         @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  order          Int
  title          String
  description    String          @db.Text
  concept        String
  estimatedTime  String
  difficulty     String
  tags           String[]
  status         MilestoneStatus @default(UNLOCKED)
  conceptContent String?         @db.Text
  starterCode      String?         @db.Text
  starterFiles     Json?           // snapshot of files at generation — used for "Reset milestone"
  code             String?         @db.Text
  files            Json?           // multi-file: { "index.html": "...", "style.css": "...", "script.js": "..." }
  tasks            Json?
  completedTaskIds String[]        @default([])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  messages         MilestoneMessage[]

  @@unique([roadmapId, order])
}

model MilestoneMessage {
  id          String    @id @default(cuid())
  milestoneId String
  milestone   Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  role        String
  content     String    @db.Text
  createdAt   DateTime  @default(now())
}

enum MilestoneStatus {
  LOCKED
  UNLOCKED
  IN_PROGRESS
  COMPLETED
}

model Message {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model Quiz {
  id          String    @id @default(cuid())
  projectId   String    @unique
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questions   Json
  answers     Json?
  score       Float?
  level       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
}

enum ProjectStatus {
  ONBOARDING
  QUIZ
  ACTIVE
  COMPLETED
}
